{
  "name": "prm-deductions-gp2gp-messenger",
  "version": "1.0.0",
  "description": "GP2GP Messenger Service for making and receiving Health Records using GP2GP",
  "main": "src/server.js",
  "scripts": {
    "check-audit": "check-audit",
    "resolve-audit": "resolve-audit",
    "lint": "eslint src/ scripts/",
    "lint:fix": "npm run lint -- --fix",
    "test": "npm run lint:fix && npm run test:unit && npm run test:integration",
    "test:coverage-unit-test-only": "jest src/ --testPathIgnorePatterns=\"**/*integration.test.js\" --maxWorkers=1 --coverage --detectOpenHandles --forceExit --setupFiles dotenv/config",
    "test:unit": "NODE_OPTIONS=--experimental-vm-modules jest src/ --setupFiles dotenv/config --detectOpenHandles",
    "test:integration": "NODE_OPTIONS=--experimental-vm-modules jest src/ --testMatch=\"**/*integration.test.js\" --detectOpenHandles --forceExit --setupFiles dotenv/config",
    "test:functional": "jest test/functional/*",
    "test:functional:opentest": "jest \"test/functional/\" --testPathIgnorePatterns=\"test/functional/health-record-requests.test.js\"",
    "test:e2e": "jest test/e2e/*",
    "test:docker": "jest test/docker/*",
    "test:watch": "jest src/ --testPathIgnorePatterns=\"**/*integration.test.js\" --setupFiles dotenv/config --watch",
    "test:coverage": "jest src/ --maxWorkers=1 --coverage --detectOpenHandles --forceExit --setupFiles dotenv/config",
    "build": "babel src -d build --ignore '**/*.test.js' --ignore '**/__mocks__/*' --ignore '**/__tests__/*' && cp src/*.json build",
    "start": "node build/server.js",
    "start:local": "babel-node -r dotenv/config src/server.js",
    "start:nodemon": "nodemon --exec babel-node -r dotenv/config src/server.js"
  },
  "dependencies": {
    "@aws-sdk/client-sqs": "^3.470.0",
    "@aws-sdk/client-ssm": "^3.1017.0",
    "@babel/runtime": "^7.17.8",
    "axios": "^1.13.6",
    "dateformat": "^5.0.3",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-validator": "^7.3.1",
    "express-winston": "^4.2.0",
    "fast-xml-parser": "^5.5.9",
    "helmet": "^8.1.0",
    "lodash.clonedeep": "^4.5.0",
    "lodash.isequal": "^4.5.0",
    "lodash.merge": "^4.6.2",
    "npm-audit-resolver": "3.0.0-7",
    "swagger-ui-express": "^5.0.1",
    "traverse": "^0.6.11",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "xml2js": "^0.6.2",
    "xmlserializer": "^0.6.1"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@babel/core": "^7.29.0",
    "@babel/node": "^7.29.0",
    "@babel/plugin-transform-runtime": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.1",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "jest-when": "^4.0.1",
    "nock": "^14.0.11",
    "npm-force-resolutions": "0.0.10",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testPathIgnorePatterns": [
      ".*/__tests__/data/.*",
      ".*/test-utils.js",
      ".*/test/e2e/.*",
      ".*/test/functional/.*",
      "integration\\.test\\.js$"
    ],
    "resetModules": true,
    "clearMocks": true,
    "automock": false
  },
  "overrides": {
    "glob-parent": "^6.0.1",
    "json5": "2.2.2",
    "superagent": "8.0.8",
    "semver": ">=7.5.2",
    "qs": "^6.15.0"
  }
}
